{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API KantinITH",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest --testPathPattern=tests/ --forceExit",
    "test:coverage": "jest --testPathPattern=tests/ --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "config/db.js",
      "controllers/menuController.js",
      "middleware/auth.js",
      "models/**/*.js",
      "routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    }
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.0",
    "midtrans-client": "^1.4.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
